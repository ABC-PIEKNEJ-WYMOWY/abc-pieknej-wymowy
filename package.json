{
	"dependencies": {
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/types": "20.5.0",
		"@release-it/conventional-changelog": "10.0.6",
		"@storybook/svelte-vite": "10.3.3",
		"@storybook/sveltekit": "10.3.3",
		"@stylistic/eslint-plugin": "5.10.0",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.55.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@types/node": "25.5.0",
		"@typescript-eslint/parser": "8.57.2",
		"eslint": "10.1.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-perfectionist": "5.7.0",
		"eslint-plugin-storybook": "10.3.3",
		"eslint-plugin-svelte": "3.16.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"expect": "30.3.0",
		"jiti": "2.6.1",
		"playwright": "1.58.2",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"release-it": "19.2.4",
		"sass-embedded": "1.99.0",
		"storybook": "10.3.3",
		"stylelint": "17.6.0",
		"stylelint-config-html": "1.1.0",
		"svelte": "5.55.1",
		"svelte-check": "4.4.5",
		"svelte-eslint-parser": "1.6.0",
		"testcontainers": "11.12.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.2",
		"vite": "8.0.3"
	},
	"engines": {
		"node": ">=24.14.0",
		"npm": ">=11.9.0"
	},
	"name": "abc-pieknej-wymowy",
	"repository": {
		"type": "git",
		"url": "http://git.ztrans.pl:3000/it/abc-pieknej-wymowy.git"
	},
	"scripts": {
		"build": "node --env-file-if-exists='./.env' ./node_modules/.bin/svelte-kit sync && node --env-file-if-exists='./.env' ./node_modules/.bin/vite build --configLoader=native",
		"commitlint:check:last": "node --env-file-if-exists='./.env' ./node_modules/.bin/commitlint --last --strict",
		"commitlint:check:range": "node --env-file-if-exists='./.env' ./node_modules/.bin/commitlint --strict",
		"eslint:check": "node --env-file-if-exists='./.env' ./node_modules/.bin/svelte-kit sync && node --env-file-if-exists='./.env' ./node_modules/.bin/eslint --max-warnings=0 .",
		"eslint:fix": "node --env-file-if-exists='./.env' ./node_modules/.bin/svelte-kit sync && node --env-file-if-exists='./.env' ./node_modules/.bin/eslint --fix --max-warnings=0 .",
		"prettier:check": "node --env-file-if-exists='./.env' ./node_modules/.bin/prettier --check .",
		"prettier:fix": "node --env-file-if-exists='./.env' ./node_modules/.bin/prettier --write .",
		"release-it": "node --env-file-if-exists='./.env' ./node_modules/.bin/release-it --config='./release-it.config.ts'",
		"start:build": "node --env-file-if-exists='./.env' ./build/server/chunks/hooks.server-*.js",
		"start:development": "node --env-file-if-exists='./.env' ./node_modules/.bin/vite dev --configLoader=native",
		"storybook": "node --env-file-if-exists='./.env' ./node_modules/.bin/storybook dev --config-dir='./storybook' --exact-port --port=6006",
		"stylelint:check": "node --env-file-if-exists='./.env' ./node_modules/.bin/stylelint '**/*.{css,scss,svelte}' --max-warnings=0",
		"stylelint:fix": "node --env-file-if-exists='./.env' ./node_modules/.bin/stylelint '**/*.{css,scss,svelte}' --fix --max-warnings=0",
		"sveltekit:check": "node --env-file-if-exists='./.env' ./node_modules/.bin/svelte-kit sync && node --env-file-if-exists='./.env' ./node_modules/.bin/svelte-check --fail-on-warnings --tsconfig='./tsconfig.json'",
		"test:check": "node --env-file-if-exists='./.env' --experimental-test-coverage --test --test-concurrency=1 --test-coverage-exclude='**/*.test.*' --test-coverage-exclude='hook-for-loading-TypeScript/**/*' --test-coverage-exclude='node_modules/**/*' --test-coverage-exclude='testing/**/*' --test-coverage-include='source/**/*' --test-global-setup='./testing/entrypoint-of-testing.ts' '**/*.test.ts'",
		"test:check:integration": "node --env-file-if-exists='./.env' --test --test-concurrency=1 --test-global-setup='./testing/entrypoint-of-testing.ts' '**/*.integration.test.ts'",
		"test:check:system": "node --env-file-if-exists='./.env' --test --test-concurrency=1 --test-global-setup='./testing/entrypoint-of-testing.ts' '**/*.system.test.ts'",
		"test:check:unit": "node --env-file-if-exists='./.env' --test --test-global-setup='./testing/entrypoint-of-testing.ts' '**/*.unit.test.ts'"
	},
	"type": "module",
	"version": "1.0.0"
}
